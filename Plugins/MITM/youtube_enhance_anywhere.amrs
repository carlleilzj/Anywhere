# Anywhere MITM — YouTube Enhance (protobuf native)
name     = YouTube (Music) Enhance - Anywhere
hostname = googlevideo.com, youtubei.googleapis.com, doubleclick.net, googlesyndication.com, googleadservices.com, googleads.g.doubleclick.net

# URL-level ad blocking
0, 0, ^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad, 2
0, 0, ^https?:\/\/googleads\.g\.doubleclick\.net\/pagead\/, 2
0, 0, ^https?:\/\/pagead2\.googlesyndication\.com\/pagead\/, 2
0, 0, ^https?:\/\/[\w-]+\.doubleclick\.net\/.*\/ad, 2
0, 0, ^https?:\/\/static\.doubleclick\.net\/instream\/, 2

# Protobuf response processor (bypasses qr(), no globalThis.w race)
1, 100, ^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch))(\?(.*))?$, 
