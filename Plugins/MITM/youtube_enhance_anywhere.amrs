# Anywhere MITM plugin — YouTube (Music) Enhance
# Converted from Surge module: YouTube_surge_module_original.module
#
# Features:
# - Block googlevideo initplayback ad requests
# - Remove ad placements/slots/breaks from all YouTube API responses
# - Remove Upload, Shorts, and Immersive buttons from sidebar/guide
# - Remove Shorts shelf containers from browse/search feeds
# - Remove overlay ads from Shorts/reel feed
# - Enable Picture-in-Picture in player responses
# - Enable background playback in player responses
name     = YouTube (Music) Enhance - Anywhere
hostname = googlevideo.com, youtubei.googleapis.com

# Reject googlevideo initplayback ad requests with 200 text
0, 0, ^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad, 2

# Native Anywhere response script
1, 100, ^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch))(\?(.*))?$
, 
