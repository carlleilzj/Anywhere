# Anywhere MITM plugin — YouTube (Music) Enhance
# Converted from Surge module
#
# Features:
# - Block googlevideo initplayback ad requests
# - Remove ads from all YouTube API responses
# - Remove Upload / Shorts / Immersive buttons from sidebar
# - Remove Shorts shelves from feeds
# - Remove overlay ads from Shorts/reel
# - Enable PiP and background playback
# - Lyrics translation (async)
# - Caption translation support
# - Background playback setting toggle
name     = YouTube (Music) Enhance - Anywhere
hostname = googlevideo.com, youtubei.googleapis.com

# Reject googlevideo initplayback ad requests with 200 text
0, 0, ^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad, 2

# Native Anywhere async response script — all on one line per spec
1, 100, ^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch))(\?(.*))?$, 
