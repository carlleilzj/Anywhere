# Anywhere native script plugin
# Features:
# - Block googlevideo initplayback ad requests
# - Remove YouTube JSON ad placements / ad slots
# - Remove common Shorts containers in browse/search/guide responses
name     = YouTube Anywhere Native Ad-Block
hostname = googlevideo.com, youtubei.googleapis.com

# Reject googlevideo initplayback ad requests with 200 text
0, 0, ^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad, 2

# Native Anywhere response script
1, 100, ^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch))(\?(.*))?$
, 
